@@ -0,0 +1,15 @@
+[Unit]
+Description=BMC SoC Core Temperature Sensor
+StopWhenUnneeded=false
+Requires=xyz.openbmc_project.EntityManager.service
+After=xyz.openbmc_project.EntityManager.service
+
+[Service]
+Type=dbus
+BusName=xyz.openbmc_project.BmcTempSensor
+Restart=always
+RestartSec=5
+ExecStart=/usr/libexec/dbus-sensors/bmctempsensor
+
+[Install]
+WantedBy=multi-user.target
diff --git a/src/hpe-temp/BmcTempMain.cpp b/src/hpe-temp/BmcTempMain.cpp
new file mode 100644
index 0000000..8627f87
--- /dev/null
+++ b/src/hpe-temp/BmcTempMain.cpp
@@ -0,0 +1,224 @@
+/*
+ * Copyright (c) 2021 Hewlett-Packard Development Company, L.P.
+ *
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *      http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#include "BmcTempSensor.hpp"
+#include "Thresholds.hpp"
+#include "Utils.hpp"
+
+#include <boost/asio/io_context.hpp>
+#include <boost/asio/post.hpp>
+#include <boost/asio/steady_timer.hpp>
+#include <boost/container/flat_map.hpp>
+#include <phosphor-logging/lg2.hpp>
+#include <sdbusplus/asio/connection.hpp>
+#include <sdbusplus/asio/object_server.hpp>
+#include <sdbusplus/bus/match.hpp>
+#include <sdbusplus/message.hpp>
+#include <sdbusplus/message/native_types.hpp>
+
+#include <array>
+#include <chrono>
+#include <filesystem>
+#include <functional>
+#include <memory>
+#include <string>
+#include <utility>
+#include <vector>
+
+// Short type name used with GetSensorConfiguration / setupPropertiesChangedMatches
+// (those helpers prepend "xyz.openbmc_project.Configuration." themselves).
+static constexpr std::string_view sensorType = "BmcTempSensor";
+
+// Full D-Bus interface name, used when searching the ManagedObjectType map
+// returned by GetSensorConfiguration (keys are full interface names).
+static constexpr std::string_view sensorInterface =
+    "xyz.openbmc_project.Configuration.BmcTempSensor";
+
+static constexpr float pollRateDefault = 0.5F; // seconds
+
+// The BMC SoC core temperature is presented as a platform hwmon device
+// via the kernel coretemp driver.  Identify it by the sysfs symlink
+// name rather than an I2C bus/address (it has neither).
+static constexpr std::string_view coretempDeviceSuffix = "c0000130.coretemp";
+
+namespace fs = std::filesystem;
+
+// Returns true if the hwmon directory belongs to the BMC SoC coretemp device.
+static bool isBmcSocTemp(const fs::path& hwmonDir)
+{
+    std::error_code ec;
+    fs::path device = fs::read_symlink(hwmonDir / "device", ec);
+    if (ec)
+    {
+        return false;
+    }
+    return device.filename().string().ends_with(coretempDeviceSuffix);
+}
+
+void createSensors(
+    boost::asio::io_context& io,
+    sdbusplus::asio::object_server& objectServer,
+    boost::container::flat_map<std::string, std::shared_ptr<BmcTempSensor>>&
+        sensors,
+    std::shared_ptr<sdbusplus::asio::connection>& dbusConnection)
+{
+    auto getter = std::make_shared<GetSensorConfiguration>(
+        dbusConnection,
+        [&io, &objectServer, &sensors,
+         &dbusConnection](const ManagedObjectType& sensorConfigurations) {
+            // Find all hwmon temp input files under /sys/class/hwmon.
+            std::vector<fs::path> paths;
+            findFiles(fs::path("/sys/class/hwmon"), R"(temp\d+_input)", paths);
+
+            for (const auto& path : paths)
+            {
+                const fs::path hwmonDir = path.parent_path();
+
+                // Only process the BMC SoC coretemp device.
+                if (!isBmcSocTemp(hwmonDir))
+                {
+                    continue;
+                }
+
+                // Find the matching BmcTempSensor configuration in Entity
+                // Manager.  There is exactly one coretemp device on the BMC
+                // SoC, so we match the first config of this type.
+                const SensorData* sensorData = nullptr;
+                const std::string* configurationPath = nullptr;
+                const SensorBaseConfigMap* baseConfigMap = nullptr;
+
+                for (const auto& [objPath, cfgData] : sensorConfigurations)
+                {
+                    auto sensorBase = cfgData.find(std::string(sensorInterface));
+                    if (sensorBase == cfgData.end())
+                    {
+                        continue;
+                    }
+                    sensorData = &cfgData;
+                    configurationPath = &objPath.str;
+                    baseConfigMap = &sensorBase->second;
+                    break;
+                }
+
+                if (configurationPath == nullptr)
+                {
+                    lg2::error(
+                        "BmcTempSensor: no Entity Manager configuration found "
+                        "for '{PATH}'",
+                        "PATH", path.string());
+                    continue;
+                }
+
+                // Extract sensor name.
+                auto findName = baseConfigMap->find("Name");
+                if (findName == baseConfigMap->end())
+                {
+                    lg2::error(
+                        "BmcTempSensor: configuration missing 'Name' for "
+                        "'{PATH}'",
+                        "PATH", path.string());
+                    continue;
+                }
+                const std::string sensorName =
+                    std::get<std::string>(findName->second);
+
+                // Extract optional poll rate override.
+                float pollRate = pollRateDefault;
+                auto findRate = baseConfigMap->find("PollRate");
+                if (findRate != baseConfigMap->end())
+                {
+                    pollRate = static_cast<float>(
+                        std::visit(VariantToDoubleVisitor(),
+                                   findRate->second));
+                    if (pollRate <= 0.0F)
+                    {
+                        pollRate = pollRateDefault;
+                    }
+                }
+
+                // Extract threshold data.
+                std::vector<thresholds::Threshold> sensorThresholds;
+                if (!parseThresholdsFromConfig(*sensorData, sensorThresholds))
+                {
+                    lg2::error(
+                        "BmcTempSensor: failed to parse thresholds for '{NAME}'",
+                        "NAME", sensorName);
+                }
+
+                lg2::info(
+                    "BmcTempSensor: creating sensor '{NAME}' from '{PATH}'",
+                    "NAME", sensorName, "PATH", path.string());
+
+                // Destroy any previous instance before re-creating.
+                sensors[sensorName] = nullptr;
+                sensors[sensorName] = std::make_shared<BmcTempSensor>(
+                    path.string(), std::string(sensorInterface), objectServer,
+                    dbusConnection, io, sensorName,
+                    std::move(sensorThresholds), *configurationPath, pollRate);
+                sensors[sensorName]->setupRead();
+            }
+        });
+    getter->getConfiguration(
+        std::to_array<std::string_view>({sensorType})); // short name; prefix added internally
+}
+
+int main()
+{
+    boost::asio::io_context io;
+    auto dbusConnection =
+        std::make_shared<sdbusplus::asio::connection>(io);
+    dbusConnection->request_name("xyz.openbmc_project.BmcTempSensor");
+
+    sdbusplus::asio::object_server objectServer(dbusConnection);
+    objectServer.add_manager("/xyz/openbmc_project/sensors");
+
+    boost::container::flat_map<std::string, std::shared_ptr<BmcTempSensor>>
+        sensors;
+
+    boost::asio::post(io, [&]() {
+        createSensors(io, objectServer, sensors, dbusConnection);
+    });
+
+    // Rescan timer used after a configuration change signal.
+    boost::asio::steady_timer filterTimer(io);
+
+    // Lambda that schedules a debounced rescan on configuration changes.
+    auto eventHandler = [&](sdbusplus::message_t& message) {
+        if (message.is_method_error())
+        {
+            lg2::error("BmcTempSensor: callback method error");
+            return;
+        }
+        filterTimer.expires_after(std::chrono::seconds(1));
+        filterTimer.async_wait([&](const boost::system::error_code& ec) {
+            if (ec == boost::asio::error::operation_aborted)
+            {
+                return;
+            }
+            createSensors(io, objectServer, sensors, dbusConnection);
+        });
+    };
+
+    std::vector<std::unique_ptr<sdbusplus::bus::match_t>> matches =
+        setupPropertiesChangedMatches(
+            *dbusConnection,
+            std::to_array<std::string_view>({sensorType}),
+            eventHandler);
+
+    setupManufacturingModeMatch(*dbusConnection);
+    io.run();
+    return 0;
+}
