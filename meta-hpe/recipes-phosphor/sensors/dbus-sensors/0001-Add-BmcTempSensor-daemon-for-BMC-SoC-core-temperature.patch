+#pragma once
+
+#include "Thresholds.hpp"
+#include "sensor.hpp"
+
+#include <boost/asio/io_context.hpp>
+#include <boost/asio/random_access_file.hpp>
+#include <boost/asio/steady_timer.hpp>
+#include <sdbusplus/asio/connection.hpp>
+#include <sdbusplus/asio/object_server.hpp>
+
+#include <array>
+#include <memory>
+#include <string>
+#include <vector>
+
+// Sensor daemon for the BMC SoC core temperature, which is exposed as a
+// platform hwmon device (c0000130.coretemp) rather than an I2C device.
+// This makes it incompatible with HwmonTempSensor's I2C bus/addr matching.
+class BmcTempSensor :
+    public Sensor,
+    public std::enable_shared_from_this<BmcTempSensor>
+{
+  public:
+    // pollRate is in seconds (fractional allowed, e.g. 0.5 = 500 ms)
+    BmcTempSensor(const std::string& path, const std::string& objectType,
+                  sdbusplus::asio::object_server& objectServer,
+                  std::shared_ptr<sdbusplus::asio::connection>& conn,
+                  boost::asio::io_context& io, const std::string& sensorName,
+                  std::vector<thresholds::Threshold>&& thresholdsIn,
+                  const std::string& sensorConfiguration, float pollRate);
+    ~BmcTempSensor() override;
+    void setupRead();
+
+  private:
+    // Ordering: readBuf first so it outlives async ops on other members.
+    std::array<char, 128> readBuf{};
+    sdbusplus::asio::object_server& objServer;
+    boost::asio::random_access_file inputDev;
+    boost::asio::steady_timer waitTimer;
+    std::string path;
+    unsigned int sensorPollMs;
+
+    // The kernel coretemp driver reports millidegrees C; scale to degrees C.
+    static constexpr double scaleValue = 0.001;
+    static constexpr double maxReading = 127.0;
+    static constexpr double minReading = -128.0;
+
+    void handleResponse(const boost::system::error_code& err,
+                        std::size_t bytesRead);
+    void restartRead();
+    void checkThresholds() override;
+};
