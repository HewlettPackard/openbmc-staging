/*
 * Device Tree Source Overlay for HPE ProLiant platform 0x0284
 * Auto-generated by platdef_parser.py from BIOS platdef data.
 *
 * i2cmux@N = platdef Engine N  |  sel value = i2cN@sel in child node
 *
 * i2cmux@3 (CPLD 0x87): 8 UBM channel(s), sel 1-8
 * i2cmux@4 (CPLD 0x88): 4 UBM channel(s), sel 9-12
 * i2cmux@8 (CPLD 0x8c): 16 UBM channel(s), sel 1-16
 * i2cmux@6: Power Supply 2 (psu2) sel=13 addr=0x5c
 * i2cmux@7: Power Supply 1 (psu1) sel=1 addr=0x5c
 */

/ {
