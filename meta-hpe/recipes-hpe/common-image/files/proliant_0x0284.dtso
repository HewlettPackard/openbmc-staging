						drveeprom@53 {
							compatible = "atmel,24c02";
							label = "drv52";
							reg = <0x53>;
						};
						thermsensor@1b {
							compatible = "ubm-drv";
							uid-led = <&leddrv2_25>;
							reg = <0x1b>;
						};
					};
				};
			}; /* i2c8@14 */

			/* sel=15  NVMe+SATA  (PCA9546 switch) */
			i2c8@15 {
				piceeprom26: piceeprom26 {
					compatible = "atmel,24c02";
					label = "piceeprom26";
					reg = <0x57>;
				};
				ubm26: ubm@40 {
					compatible = "ubm4";
					eeprom_phandle = <&piceeprom26>;
					reg = <0x40>;
					#gpio-cells = <2>;
					gpio-line-names = "0_DRV1_PRESENCE", "0_DRV1_UUID", "0_DRV1_ACT",
						"0_DRV2_PRESENCE", "0_DRV2_UUID", "0_DRV2_ACT";
				};
				switch@72 {
					compatible = "nxp,pca9546";
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0x72>;
					i2c@0 {
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <0>;
						drveeprom@53 {
							compatible = "atmel,24c02";
							label = "drv53";
							reg = <0x53>;
						};
						thermsensor@1b {
							compatible = "ubm-drv";
							uid-led = <&leddrv1_26>;
							reg = <0x1b>;
						};
					};
					i2c@1 {
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <1>;
						drveeprom@53 {
							compatible = "atmel,24c02";
							label = "drv54";
							reg = <0x53>;
						};
						thermsensor@1b {
							compatible = "ubm-drv";
							uid-led = <&leddrv2_26>;
							reg = <0x1b>;
						};
					};
				};
			}; /* i2c8@15 */

			/* sel=16  NVMe+SATA  (PCA9546 switch) */
			i2c8@16 {
				piceeprom27: piceeprom27 {
					compatible = "atmel,24c02";
					label = "piceeprom27";
					reg = <0x57>;
				};
				ubm27: ubm@40 {
					compatible = "ubm4";
					eeprom_phandle = <&piceeprom27>;
					reg = <0x40>;
					#gpio-cells = <2>;
					gpio-line-names = "0_DRV1_PRESENCE", "0_DRV1_UUID", "0_DRV1_ACT",
						"0_DRV2_PRESENCE", "0_DRV2_UUID", "0_DRV2_ACT";
				};
				switch@72 {
					compatible = "nxp,pca9546";
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0x72>;
					i2c@0 {
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <0>;
						drveeprom@53 {
							compatible = "atmel,24c02";
							label = "drv55";
							reg = <0x53>;
						};
						thermsensor@1b {
							compatible = "ubm-drv";
							uid-led = <&leddrv1_27>;
							reg = <0x1b>;
						};
					};
					i2c@1 {
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <1>;
						drveeprom@53 {
							compatible = "atmel,24c02";
							label = "drv56";
							reg = <0x53>;
						};
						thermsensor@1b {
							compatible = "ubm-drv";
							uid-led = <&leddrv2_27>;
							reg = <0x1b>;
						};
					};
				};
			}; /* i2c8@16 */

		}; /* __overlay__ */
	}; /* fragment@2 */

	/*
	 * fragment@3: Engine 6 / i2cmux@6 — PSU(s)
	 */
	fragment@3 {
		target-path = "/ahb@80000000/i2cmux@6";
		__overlay__ {

			/* Power Supply 2 */
			i2c6@13 {
				psu2: psu@5c {
					compatible = "hpe,crps185";
					reg = <0x5c>;
				};
			}; /* i2c6@13 */

		}; /* __overlay__ */
	}; /* fragment@3 */

	/*
	 * fragment@4: Engine 7 / i2cmux@7 — PSU(s)
	 */
	fragment@4 {
		target-path = "/ahb@80000000/i2cmux@7";
		__overlay__ {

			/* Power Supply 1 */
			i2c7@1 {
				psu1: psu@5c {
					compatible = "hpe,crps185";
					reg = <0x5c>;
				};
			}; /* i2c7@1 */

		}; /* __overlay__ */
	}; /* fragment@4 */

