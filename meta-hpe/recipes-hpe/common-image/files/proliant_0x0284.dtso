					compatible = "atmel,24c02";
					label = "piceeprom0";
					reg = <0x57>;
				};
				ubm0: ubm@40 {
					compatible = "ubm4";
					eeprom_phandle = <&piceeprom0>;
					reg = <0x40>;
					#gpio-cells = <2>;
					gpio-line-names = "0_DRV1_PRESENCE", "0_DRV1_UUID", "0_DRV1_ACT",
						"0_DRV2_PRESENCE", "0_DRV2_UUID", "0_DRV2_ACT";
